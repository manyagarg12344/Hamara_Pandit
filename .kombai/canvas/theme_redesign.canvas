      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-primary: #121212;\n    --bg-secondary: #1c1c1c;\n    --bg-card: #1c1c1c;\n    --bg-glass: rgba(18, 18, 18, 0.8);\n    --text-primary: #F5F5F5;\n    --text-secondary: #A0A0A0;\n    --text-muted: #666666;\n    --border-color: rgba(212, 175, 55, 0.2);\n    --shadow-color: rgba(0, 0, 0, 0.6);\n    --shadow-glow: rgba(255, 191, 0, 0.25);\n\n    --gem-gold: #D4AF37;\n    --gem-gold-light: #FFD700;\n    --gem-amber: #FFBF00;\n    \n    --gradient-hero: linear-gradient(135deg, #0a0a0a 0%, #121212 50%, #1c1300 100%);\n    --gradient-card: linear-gradient(145deg, #1c1c1c 0%, #121212 100%);\n    --gradient-gold: linear-gradient(135deg, #D4AF37 0%, #FFBF00 100%);\n    \n    --font-display: 'Playfair Display', serif;\n    --font-body: 'Lato', sans-serif;\n    \n    --radius-lg: 24px;\n    --transition-base: 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  body {\n    background-color: var(--bg-primary);\n    color: var(--text-primary);\n    font-family: var(--font-body);\n    margin: 0;\n    line-height: 1.6;\n    overflow-x: hidden;\n  }\n\n  .premium-glow {\n    position: absolute;\n    filter: blur(120px);\n    z-index: 0;\n    pointer-events: none;\n  }\n\n  .text-gradient {\n    background: var(--gradient-gold);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    background-clip: text;\n  }\n\n  .btn-gold {\n    background: var(--gradient-gold);\n    color: #121212;\n    padding: 16px 36px;\n    border-radius: 9999px;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n    border: none;\n    cursor: pointer;\n    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.4);\n    transition: var(--transition-base);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .btn-gold::after {\n    content: '';\n    position: absolute;\n    top: -50%;\n    left: -60%;\n    width: 20%;\n    height: 200%;\n    background: rgba(255, 255, 255, 0.4);\n    transform: rotate(30deg);\n    transition: 0.6s;\n  }\n\n  .btn-gold:hover::after {\n    left: 120%;\n  }\n\n  .btn-gold:hover {\n    transform: translateY(-3px);\n    box-shadow: 0 8px 30px rgba(212, 175, 55, 0.6);\n  }\n\n  .nav-blur {\n    backdrop-filter: blur(20px);\n    border-bottom: 1px solid var(--border-color);\n  }\n\n  .card-premium {\n    background: var(--bg-card);\n    border: 1px solid var(--border-color);\n    border-radius: var(--radius-lg);\n    transition: var(--transition-base);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .card-premium:hover {\n    border-color: var(--gem-gold);\n    transform: translateY(-8px);\n    box-shadow: 0 20px 40px rgba(0,0,0,0.4), 0 0 20px var(--shadow-glow);\n  }\n\n  .zodiac-medallion {\n    width: 80px;\n    height: 80px;\n    border-radius: 50%;\n    background: #1c1c1c;\n    border: 1px solid var(--gem-gold);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 2rem;\n    transition: var(--transition-base);\n    cursor: pointer;\n    position: relative;\n    box-shadow: inset 0 0 10px rgba(212, 175, 55, 0.2);\n  }\n\n  .zodiac-medallion:hover {\n    background: var(--gem-gold);\n    color: #121212;\n    transform: scale(1.1) rotate(5deg);\n  }\n\n  .gem-ring {\n    position: absolute;\n    border: 1px solid rgba(212, 175, 55, 0.15);\n    border-radius: 50%;\n  }\n</style>\n\n<div class=\"relative\" data-kid=\"1\">\n  \n  <nav class=\"fixed top-0 w-full z-50 nav-blur py-6 px-12 flex justify-between items-center\" data-kid=\"2\">\n    <a href=\"#\" class=\"font-[var(--font-display)] text-2xl font-bold flex items-center gap-3\" data-kid=\"3\">\n      <span class=\"text-[var(--gem-gold)]\" data-kid=\"4\"><i class=\"ti ti-star-filled\" data-kid=\"5\"></i></span>\n      <span class=\"tracking-widest uppercase text-sm\" data-kid=\"6\">Gemstone Vault</span>\n    </a>\n    <div class=\"flex items-center gap-10\" data-kid=\"7\">\n      <div class=\"hidden md:flex gap-8 text-sm font-medium uppercase tracking-wider text-[var(--text-secondary)]\" data-kid=\"8\">\n        <a href=\"#\" class=\"hover:text-[var(--gem-gold)] transition-colors\" data-kid=\"9\">Oracle</a>\n        <a href=\"#\" class=\"hover:text-[var(--gem-gold)] transition-colors\" data-kid=\"10\">Zodiac</a>\n        <a href=\"#\" class=\"hover:text-[var(--gem-gold)] transition-colors\" data-kid=\"11\">History</a>\n      </div>\n      <button class=\"w-10 h-10 rounded-full border border-[var(--border-color)] flex items-center justify-center hover:bg-[var(--gem-gold)] hover:text-[#121212] transition-colors\" data-kid=\"12\">\n        <i class=\"ti ti-moon\" data-kid=\"13\"></i>\n      </button>\n    </div>\n  </nav>\n\n  \n  <section class=\"min-height-[100vh] pt-32 pb-20 relative flex items-center overflow-hidden\" data-kid=\"14\">\n    \n    <video src=\"https://videos.pexels.com/video-files/5561390/5561390-sd_960_540_25fps.mp4\" poster=\"https://images.pexels.com/videos/5561390/abstract-dust-flow-gravitation-5561390.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"absolute inset-0 w-full h-full object-cover opacity-20\" data-kid=\"15\"></video>\n    <div class=\"premium-glow w-[600px] h-[600px] bg-[var(--gem-amber)]/20 -top-20 -right-20\" data-kid=\"16\"></div>\n    <div class=\"premium-glow w-[400px] h-[400px] bg-[var(--gem-gold)]/10 bottom-0 left-0\" data-kid=\"17\"></div>\n\n    <div class=\"container mx-auto px-12 relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center\" data-kid=\"18\">\n      <div id=\"hero-text-anim\" data-kid=\"19\">\n        <div class=\"inline-block px-4 py-1 border border-[var(--gem-gold)]/40 rounded-full text-[10px] font-bold tracking-[0.2em] text-[var(--gem-gold)] mb-8 uppercase\" data-kid=\"20\">\n          Ethereal Astrology • AI Driven\n        </div>\n        <h1 class=\"font-[var(--font-display)] text-7xl lg:text-8xl leading-[0.9] mb-10\" data-kid=\"21\">\n          Discover Your <br data-kid=\"22\"> \n          <span class=\"text-gradient italic\" data-kid=\"23\">True Gem</span>\n        </h1>\n        <p class=\"text-[var(--text-secondary)] text-lg max-w-md mb-12 font-light leading-relaxed\" data-kid=\"24\">\n          Unlock the cosmic secrets hidden within your birth charts. Our AI oracle reveals the gemstone that resonates with your unique celestial frequency.\n        </p>\n        <div class=\"flex gap-6\" data-kid=\"25\">\n          <button class=\"btn-gold\" data-kid=\"26\">Begin Revelation</button>\n          <button class=\"px-8 py-4 rounded-full border border-[var(--border-color)] text-sm font-bold uppercase tracking-wider hover:bg-white/5 transition-colors\" data-kid=\"27\">View Catalog</button>\n        </div>\n      </div>\n\n      <div class=\"relative flex items-center justify-center py-20\" data-kid=\"28\">\n        \n        <div id=\"gem-container\" class=\"relative w-80 h-80 flex items-center justify-center\" data-kid=\"29\">\n          \n          <div class=\"gem-ring w-full h-full\" data-kid=\"30\"></div>\n          <div class=\"gem-ring w-[120%] h-[120%] opacity-50\" data-kid=\"31\"></div>\n          <div class=\"gem-ring w-[140%] h-[140%] opacity-30\" data-kid=\"32\"></div>\n          \n          \n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/double-ringed-orb.svg\" class=\"absolute w-full h-full opacity-20\" style=\"color: var(--gem-gold);\" data-kid=\"33\">\n          \n          \n          <div class=\"w-48 h-48 rounded-full bg-gradient-to-br from-[var(--gem-gold)] via-[var(--gem-amber)] to-[#8b4513] shadow-[0_0_80px_rgba(255,191,0,0.4)] flex items-center justify-center relative overflow-hidden\" data-kid=\"34\">\n             <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(255,255,255,0.4),transparent)]\" data-kid=\"35\"></div>\n             <span class=\"text-6xl filter drop-shadow(0 4px 10px rgba(0,0,0,0.3))\" data-kid=\"36\">💎</span>\n          </div>\n          \n          \n          <div class=\"absolute -top-10 -right-4 w-12 h-12 rounded-full bg-[#1c1c1c] border border-[var(--gem-gold)] flex items-center justify-center text-xl shadow-lg animate-bounce\" data-kid=\"37\">♈</div>\n          <div class=\"absolute bottom-4 -left-10 w-10 h-10 rounded-full bg-[#1c1c1c] border border-[var(--gem-gold)] flex items-center justify-center text-lg shadow-lg\" style=\"animation: float 4s ease-in-out infinite;\" data-kid=\"38\">♌</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 bg-[#0a0a0a]\" data-kid=\"39\">\n    <div class=\"container mx-auto px-12\" data-kid=\"40\">\n      <div class=\"flex flex-col md:flex-row justify-between items-end mb-20 gap-8\" data-kid=\"41\">\n        <div class=\"max-w-xl\" data-kid=\"42\">\n          <h2 class=\"font-[var(--font-display)] text-5xl mb-6\" data-kid=\"43\">The Royal Treasury</h2>\n          <p class=\"text-[var(--text-secondary)]\" data-kid=\"44\">Exquisite insights crafted through ancient wisdom and modern neural processing.</p>\n        </div>\n        <div class=\"flex gap-4\" data-kid=\"45\">\n          <button class=\"w-12 h-12 rounded-full border border-[var(--border-color)] flex items-center justify-center hover:border-[var(--gem-gold)] transition-colors\" data-kid=\"46\"><i class=\"ti ti-chevron-left\" data-kid=\"47\"></i></button>\n          <button class=\"w-12 h-12 rounded-full border border-[var(--border-color)] flex items-center justify-center hover:border-[var(--gem-gold)] transition-colors\" data-kid=\"48\"><i class=\"ti ti-chevron-right\" data-kid=\"49\"></i></button>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"50\">\n        \n        <div class=\"card-premium p-10 flex flex-col h-[420px]\" data-kid=\"51\">\n          <div class=\"w-12 h-12 bg-[var(--gem-gold)]/10 rounded-xl flex items-center justify-center text-[var(--gem-gold)] mb-8\" data-kid=\"52\">\n            <i class=\"ti ti-stars text-2xl\" data-kid=\"53\"></i>\n          </div>\n          <h3 class=\"font-[var(--font-display)] text-2xl mb-4 mt-auto\" data-kid=\"54\">Astro Analysis</h3>\n          <p class=\"text-sm text-[var(--text-secondary)] mb-8\" data-kid=\"55\">Deep celestial mapping to find stones that align with your sun, moon, and rising signs.</p>\n          <div class=\"text-[var(--gem-gold)] text-xs font-bold uppercase tracking-widest\" data-kid=\"56\">Learn More <i class=\"ti ti-arrow-right ml-2\" data-kid=\"57\"></i></div>\n        </div>\n        \n        <div class=\"card-premium p-10 flex flex-col h-[420px]\" data-kid=\"58\">\n          <div class=\"w-12 h-12 bg-[var(--gem-gold)]/10 rounded-xl flex items-center justify-center text-[var(--gem-gold)] mb-8\" data-kid=\"59\">\n            <i class=\"ti ti-sparkles text-2xl\" data-kid=\"60\"></i>\n          </div>\n          <h3 class=\"font-[var(--font-display)] text-2xl mb-4 mt-auto\" data-kid=\"61\">AI Resonance</h3>\n          <p class=\"text-sm text-[var(--text-secondary)] mb-8\" data-kid=\"62\">State-of-the-art recommendation engine simulating thousands of cosmic permutations.</p>\n          <div class=\"text-[var(--gem-gold)] text-xs font-bold uppercase tracking-widest\" data-kid=\"63\">Learn More <i class=\"ti ti-arrow-right ml-2\" data-kid=\"64\"></i></div>\n        </div>\n        \n        <div class=\"card-premium p-10 flex flex-col h-[420px]\" data-kid=\"65\">\n          <div class=\"w-12 h-12 bg-[var(--gem-gold)]/10 rounded-xl flex items-center justify-center text-[var(--gem-gold)] mb-8\" data-kid=\"66\">\n            <i class=\"ti ti-file-text text-2xl\" data-kid=\"67\"></i>\n          </div>\n          <h3 class=\"font-[var(--font-display)] text-2xl mb-4 mt-auto\" data-kid=\"68\">Digital Dossier</h3>\n          <p class=\"text-sm text-[var(--text-secondary)] mb-8\" data-kid=\"69\">Comprehensive PDF reports detailing your gemstone's properties and mystical origins.</p>\n          <div class=\"text-[var(--gem-gold)] text-xs font-bold uppercase tracking-widest\" data-kid=\"70\">Learn More <i class=\"ti ti-arrow-right ml-2\" data-kid=\"71\"></i></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-20 border-y border-[var(--border-color)]\" data-kid=\"72\">\n    <div class=\"container mx-auto px-12\" data-kid=\"73\">\n      <div class=\"flex justify-center flex-wrap gap-8 lg:gap-12\" data-kid=\"74\">\n        <div class=\"text-center group\" data-kid=\"75\">\n          <div class=\"zodiac-medallion mb-4\" data-kid=\"76\">♈</div>\n          <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40 group-hover:opacity-100 group-hover:text-[var(--gem-gold)]\" data-kid=\"77\">Aries</span>\n        </div>\n        <div class=\"text-center group\" data-kid=\"78\">\n          <div class=\"zodiac-medallion mb-4\" data-kid=\"79\">♉</div>\n          <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40 group-hover:opacity-100 group-hover:text-[var(--gem-gold)]\" data-kid=\"80\">Taurus</span>\n        </div>\n        <div class=\"text-center group\" data-kid=\"81\">\n          <div class=\"zodiac-medallion mb-4\" data-kid=\"82\">♊</div>\n          <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40 group-hover:opacity-100 group-hover:text-[var(--gem-gold)]\" data-kid=\"83\">Gemini</span>\n        </div>\n        <div class=\"text-center group\" data-kid=\"84\">\n          <div class=\"zodiac-medallion mb-4\" data-kid=\"85\">♋</div>\n          <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40 group-hover:opacity-100 group-hover:text-[var(--gem-gold)]\" data-kid=\"86\">Cancer</span>\n        </div>\n        <div class=\"text-center group\" data-kid=\"87\">\n          <div class=\"zodiac-medallion mb-4\" data-kid=\"88\">♌</div>\n          <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40 group-hover:opacity-100 group-hover:text-[var(--gem-gold)]\" data-kid=\"89\">Leo</span>\n        </div>\n        <div class=\"text-center group\" data-kid=\"90\">\n          <div class=\"zodiac-medallion mb-4\" data-kid=\"91\">♍</div>\n          <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40 group-hover:opacity-100 group-hover:text-[var(--gem-gold)]\" data-kid=\"92\">Virgo</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-40 relative overflow-hidden\" data-kid=\"93\">\n    <img src=\"https://images.unsplash.com/photo-1614069149775-7fcb87833239?auto=format&w=1440&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-20\" decoding=\"async\" loading=\"lazy\" data-kid=\"94\">\n    <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--bg-primary)] via-[var(--bg-primary)]/80 to-transparent\" data-kid=\"95\"></div>\n    \n    <div class=\"container mx-auto px-12 relative z-10 text-center\" data-kid=\"96\">\n      <h2 class=\"font-[var(--font-display)] text-6xl mb-12\" data-kid=\"97\">Claim Your Celestial Inheritance</h2>\n      <button class=\"btn-gold btn-lg\" data-kid=\"98\">Reveal Your Stone</button>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-20 px-12 border-t border-[var(--border-color)]\" data-kid=\"99\">\n    <div class=\"container mx-auto grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"100\">\n      <div class=\"md:col-span-2\" data-kid=\"101\">\n        <div class=\"font-[var(--font-display)] text-2xl font-bold mb-6\" data-kid=\"102\">Gemstone Vault</div>\n        <p class=\"text-[var(--text-secondary)] max-w-sm\" data-kid=\"103\">The world's premier digital oracle for astrological gemstone discovery and metaphysical exploration.</p>\n      </div>\n      <div data-kid=\"104\">\n        <h4 class=\"text-xs font-bold uppercase tracking-widest mb-6\" data-kid=\"105\">Explore</h4>\n        <ul class=\"text-[var(--text-secondary)] text-sm space-y-4 list-none p-0\" data-kid=\"106\">\n          <li data-kid=\"107\"><a href=\"#\" class=\"hover:text-[var(--gem-gold)]\" data-kid=\"108\">The Oracle</a></li>\n          <li data-kid=\"109\"><a href=\"#\" class=\"hover:text-[var(--gem-gold)]\" data-kid=\"110\">Catalog</a></li>\n          <li data-kid=\"111\"><a href=\"#\" class=\"hover:text-[var(--gem-gold)]\" data-kid=\"112\">Zodiac Guide</a></li>\n        </ul>\n      </div>\n      <div data-kid=\"113\">\n        <h4 class=\"text-xs font-bold uppercase tracking-widest mb-6\" data-kid=\"114\">Contact</h4>\n        <ul class=\"text-[var(--text-secondary)] text-sm space-y-4 list-none p-0\" data-kid=\"115\">\n          <li data-kid=\"116\">Instagram</li>\n          <li data-kid=\"117\">Twitter</li>\n          <li data-kid=\"118\">Metaphysics Hub</li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"container mx-auto mt-20 pt-8 border-t border-[var(--border-color)]/30 flex justify-between items-center text-[10px] font-bold uppercase tracking-widest text-[var(--text-muted)]\" data-kid=\"119\">\n      <div data-kid=\"120\">© 2026 GEMSTONE VAULT CORE</div>\n      <div class=\"flex gap-8\" data-kid=\"121\">\n        <span data-kid=\"122\">Privacy</span>\n        <span data-kid=\"123\">Terms</span>\n      </div>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"124\"></script>\n<script data-kid=\"125\">\n  // Initial Reveal\n  gsap.from(\"#hero-text-anim > *\", {\n    y: 40,\n    opacity: 0,\n    duration: 1,\n    stagger: 0.15,\n    ease: \"power4.out\"\n  });\n\n  // Gem Container floating\n  gsap.to(\"#gem-container\", {\n    y: -20,\n    duration: 3,\n    repeat: -1,\n    yoyo: true,\n    ease: \"sine.inOut\"\n  });\n\n  // Orbit rotation\n  gsap.to(\".gem-ring\", {\n    rotate: 360,\n    duration: 40,\n    repeat: -1,\n    ease: \"none\"\n  });\n\n  // Medallion hover effects (handled by CSS mostly, but adding a little subtle GSAP jitter)\n  document.querySelectorAll('.zodiac-medallion').forEach(el => {\n    el.addEventListener('mouseenter', () => {\n      gsap.to(el, { scale: 1.15, duration: 0.3, ease: \"back.out(2)\" });\n    });\n    el.addEventListener('mouseleave', () => {\n      gsap.to(el, { scale: 1, duration: 0.3, ease: \"power2.inOut\" });\n    });\n  });\n</script>",
