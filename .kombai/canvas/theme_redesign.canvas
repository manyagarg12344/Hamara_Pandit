      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-void: #050505;\n    --color-neon-orange: #FF5A00;\n    --color-liquid-gold: #FFD700;\n    --glass-bg: rgba(255, 165, 0, 0.03);\n    --glass-border: rgba(255, 90, 0, 0.2);\n    --font-display: 'Space Grotesk', sans-serif;\n    --font-body: 'Inter', sans-serif;\n  }\n\n  body {\n    background-color: var(--color-void);\n    color: #FFFFFF;\n    font-family: var(--font-body);\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-display { font-family: var(--font-display); }\n  \n  .glass {\n    background: var(--glass-bg);\n    backdrop-filter: blur(12px);\n    -webkit-backdrop-filter: blur(12px);\n    border: 1px solid var(--glass-border);\n  }\n\n  .glow-orange {\n    box-shadow: 0 0 20px rgba(255, 90, 0, 0.3);\n  }\n\n  .glow-gold {\n    box-shadow: 0 0 30px rgba(255, 215, 0, 0.4);\n  }\n\n  .text-glow-orange {\n    text-shadow: 0 0 10px rgba(255, 90, 0, 0.5);\n  }\n\n  .marquee-content {\n    display: flex;\n    animation: marquee 30s linear infinite;\n  }\n\n  .marquee-reverse {\n    animation: marquee-reverse 30s linear infinite;\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  @keyframes marquee-reverse {\n    0% { transform: translateX(-50%); }\n    100% { transform: translateX(0); }\n  }\n\n  .pulse-gold {\n    animation: pulse-gold 2s infinite ease-in-out;\n  }\n\n  @keyframes pulse-gold {\n    0%, 100% { box-shadow: 0 0 20px rgba(255, 215, 0, 0.4); transform: scale(1); }\n    50% { box-shadow: 0 0 40px rgba(255, 215, 0, 0.7); transform: scale(1.05); }\n  }\n\n  .bento-grid {\n    display: grid;\n    grid-template-columns: repeat(12, 1fr);\n    grid-template-rows: repeat(2, 400px);\n    gap: 24px;\n  }\n</style>\n\n\n<nav class=\"fixed top-0 left-0 right-0 z-50 glass border-b border-orange-500/20 py-4 px-8 flex items-center justify-between\" data-kid=\"1\">\n  <div class=\"flex items-center gap-3\" data-kid=\"2\">\n    <div class=\"w-10 h-10 rounded-lg bg-orange-600 flex items-center justify-center glow-orange\" data-kid=\"3\">\n      <i class=\"ti ti-sparkles text-white text-xl\" data-kid=\"4\"></i>\n    </div>\n    <span class=\"font-display font-bold text-xl tracking-tighter uppercase\" data-kid=\"5\">Gemstone<span class=\"text-orange-500\" data-kid=\"6\">AI</span></span>\n  </div>\n  \n  <div class=\"hidden md:flex items-center gap-8 text-sm font-medium uppercase tracking-widest text-zinc-400\" data-kid=\"7\">\n    <a href=\"#\" class=\"hover:text-orange-500 transition-colors\" data-kid=\"8\">Origins</a>\n    <a href=\"#\" class=\"hover:text-orange-500 transition-colors\" data-kid=\"9\">The Vault</a>\n    <a href=\"#\" class=\"hover:text-orange-500 transition-colors\" data-kid=\"10\">Sequence</a>\n  </div>\n\n  <div class=\"flex items-center gap-4\" data-kid=\"11\">\n    <button class=\"glass p-2 rounded-full border-orange-500/30 text-zinc-400\" data-kid=\"12\">\n      <i class=\"ti ti-moon\" data-kid=\"13\"></i>\n    </button>\n    <button class=\"bg-orange-600 px-6 py-2 rounded-full font-display font-bold text-xs uppercase tracking-widest hover:bg-orange-500 transition-all glow-orange\" data-kid=\"14\">\n      Access Core\n    </button>\n  </div>\n</nav>\n\n\n<section class=\"min-h-screen pt-32 pb-20 px-8 max-w-7xl mx-auto\" data-kid=\"15\">\n  <div class=\"bento-grid\" data-kid=\"16\">\n    \n    <div class=\"col-span-12 lg:col-span-8 glass rounded-3xl p-12 flex flex-col justify-center relative overflow-hidden group\" data-kid=\"17\">\n      <div class=\"absolute top-0 right-0 w-96 h-96 bg-orange-600/10 blur-3xl -mr-20 -mt-20 group-hover:bg-orange-500/20 transition-all\" data-kid=\"18\"></div>\n      <span class=\"text-orange-500 font-display font-bold tracking-[0.3em] uppercase mb-6 text-sm\" data-kid=\"19\">System Ready / Sequence 01</span>\n      <h1 class=\"font-display text-7xl font-black leading-none uppercase mb-8\" data-kid=\"20\">\n        Reveal Your <br data-kid=\"21\"> \n        <span class=\"bg-gradient-to-r from-orange-500 via-yellow-400 to-orange-500 bg-clip-text text-transparent\" data-kid=\"22\">Liquid Destiny</span>\n      </h1>\n      <p class=\"text-zinc-400 max-w-md text-lg font-light leading-relaxed mb-10\" data-kid=\"23\">\n        Merging ancient zodiac wisdom with advanced neural processing to decode your crystalline identity.\n      </p>\n      <div class=\"flex gap-4\" data-kid=\"24\">\n        <button class=\"bg-orange-600 px-10 py-5 rounded-2xl font-display font-black text-sm uppercase tracking-[0.2em] glow-orange hover:bg-orange-500 transition-all\" data-kid=\"25\">\n          Initiate Scan\n        </button>\n        <button class=\"glass border-white/10 px-10 py-5 rounded-2xl font-display font-black text-sm uppercase tracking-[0.2em] hover:bg-white/5 transition-all\" data-kid=\"26\">\n          Data Logs\n        </button>\n      </div>\n    </div>\n\n    \n    <div class=\"col-span-12 lg:col-span-4 glass rounded-3xl overflow-hidden relative border-gold-500/20\" data-kid=\"27\">\n      <video src=\"https://videos.pexels.com/video-files/34745269/14729592_360_640_30fps.mp4\" poster=\"https://images.pexels.com/videos/34745269/pexels-photo-34745269.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=1200&w=630\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover scale-110 opacity-80 group-hover:opacity-100 transition-opacity\" data-kid=\"28\">\n      </video>\n      <div class=\"absolute inset-0 bg-gradient-to-t from-void via-transparent to-transparent\" data-kid=\"29\"></div>\n      <div class=\"absolute bottom-8 left-8\" data-kid=\"30\">\n        <span class=\"font-display font-bold text-xl uppercase text-glow-orange\" data-kid=\"31\">Crystalli